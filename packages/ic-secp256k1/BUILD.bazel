rust_test_suite(
    name = "integration_tests",
    srcs = glob(["tests/**/*.rs"]),
    deps = [
        # Keep sorted.
        ":ic-secp256k1",
        "@crate_index//:bip32",
        "@crate_index//:bitcoin_dogecoin",
        "@crate_index//:hex",
        "@crate_index//:hex-literal",
        "@crate_index//:hmac",
        "@crate_index//:ic_principal",
        "@crate_index//:k256",
        "@crate_index//:num-bigint",
        "@crate_index//:pem",
        "@crate_index//:rand",
