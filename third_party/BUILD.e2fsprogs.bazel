"""
e2fsprogs, built from source. The bundled libuuid/libblkid are enabled so we
don't link against system copies.
"""

load("@//bazel:defs.bzl", "disable_hermetic_cc_target")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
)

configure_make(
    name = "e2fsprogs_impl",
    args = ["-j"],
    configure_in_place = True,
    configure_options = [
        # Use the bundled libuuid/libblkid rather than the host's, so the binary
        # stays self-contained.
        "--enable-libuuid",
        "--enable-libblkid",
        "--enable-fuse2fs",
        # Trim optional features that would pull in extra deps or shared libs.
        "--disable-uuidd",
        "--disable-nls",
        "--disable-tls",
        "--disable-fsck",
        # Per the upstream INSTALL doc, static binaries need ELF shared libs off.
        "--disable-elf-shlibs",
        # The e2scrub install rules write to absolute host paths (/usr/lib/udev,
        # /etc/cron.d, /usr/lib/systemd) which fails under the build sandbox.
        # Disable each by pointing them at "no".
        "--with-udev-rules-dir=no",
        "--with-crond-dir=no",
        "--with-systemd-unit-dir=no",
    ],
    env = {
        "CFLAGS": "-O2 -static -I$$EXT_BUILD_DEPS/include",
        "LDFLAGS": "-static -L$$EXT_BUILD_DEPS/lib",
    },
    lib_source = ":all_srcs",
    out_binaries = [
        "fuse2fs",
        "mke2fs",
    ],
    # We don't ship any libs out of this build; everything is folded into the
    # exported binaries.
    out_shared_libs = [],
    out_static_libs = [],
    # mke2fs is installed under sbin/ by autotools (it's a sysadmin tool);
    # rules_foreign_cc only picks up out_binaries from bin/, so move it.
    #
    # Then drop the rest of the install tree (unused & non-reproducible).
    # The headers under include/ are kept since rules_foreign_cc declares them
    # as an output.
    postfix_script = (
            "mkdir -p $$INSTALLDIR/bin" +
            " && cp misc/mke2fs $$INSTALLDIR/bin/mke2fs" +
            " && cp misc/fuse2fs $$INSTALLDIR/bin/fuse2fs"
        ),
    # Static glibc linking is a Linux/glibc thing; this isn't expected to work
    # elsewhere.
    target_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    deps = [
        "@libfuse",
    ],
)

# e2fsprogs' dependency, libfuse does not build with hermetic toolchains (meson is not happy with the zig linker),
# and building libfuse without the hermetic and e2fsprogs with the hermetic toolchain causes linking issues because of
# glibc version mismatch. So just disable the hermetic toolchain for e2fsprogs.
disable_hermetic_cc_target(
    name = "e2fsprogs",
    target = ":e2fsprogs_impl",
)

filegroup(
    name = "fuse2fs",
    srcs = [":e2fsprogs"],
    output_group = "fuse2fs",
    visibility = ["//visibility:public"],
)

filegroup(
    name = "mke2fs",
    srcs = [":e2fsprogs"],
    output_group = "mke2fs",
    visibility = ["//visibility:public"],
)
