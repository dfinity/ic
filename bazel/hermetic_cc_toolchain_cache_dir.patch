# work around race condition in zig: https://github.com/ziglang/zig/issues/23993
# hermetic_cc_toolchain ticket: https://github.com/uber/hermetic_cc_toolchain/issues/224
diff --git a/toolchain/defs.bzl b/toolchain/defs.bzl
index 6bc1819..290608c 100644
--- a/toolchain/defs.bzl
+++ b/toolchain/defs.bzl
@@ -196,8 +196,7 @@ def _zig_repository_impl(repository_ctx):
 
     if cache_prefix == "":
         if host_os == "windows":
-            local_app_data = repository_ctx.os.environ.get("LOCALAPPDATA", "")
-            cache_prefix = "{}\\zig".format(local_app_data) if local_app_data else "C:\\\\Temp\\\\zig-cache"
+            fail("windows is not supported")
         else:
             home = repository_ctx.os.environ.get("HOME", "")
             if home:
diff --git a/toolchain/zig-wrapper.zig b/toolchain/zig-wrapper.zig
index c4b1592..14695f0 100644
--- a/toolchain/zig-wrapper.zig
+++ b/toolchain/zig-wrapper.zig
@@ -207,6 +207,22 @@ fn spawnAndStripUnix(arena: mem.Allocator, params: ExecParams) u8 {
     return code;
 }
 
+fn makeSuffix(allocator: std.mem.Allocator, pwd: []const u8) ![]const u8 {
+    var it = std.mem.tokenizeScalar(u8, pwd, '/');
+
+    while (it.next()) |segment| {
+        if (std.mem.startsWith(u8, segment, "k8-opt-")) {
+            var hasher = std.hash.Wyhash.init(0);
+            hasher.update(segment);
+            const hash_value = hasher.final();
+            return std.fmt.allocPrint(allocator, "config-{x}", .{hash_value});
+        }
+    }
+
+    // no "k8-opt-" found
+    return std.fmt.allocPrint(allocator, "config-catchall", .{});
+}
+
 // argv_it is an object that has such method:
 //     fn next(self: *Self) ?[]const u8
 // in non-testing code it is *process.ArgIterator.
@@ -279,9 +295,18 @@ fn parseArgs(
         break :blk @as([]const u8, if (builtin.os.tag == .macos) "/var/tmp/zig-cache" else "/tmp/zig-cache");
     };
 
+    // Work around a race condition in zig (https://github.com/ziglang/zig/issues/23993)
+    // by giving each bazel configuration its own zig cache directory. The
+    // configuration is derived from the current working directory, which under
+    // bazel contains a "k8-opt-..." output-tree segment unique per config.
+    const pwd = cwd.realpathAlloc(arena, ".") catch |err|
+        return parseFatal(arena, "error getting cwd: {s}", .{@errorName(err)});
+    const suffix = try makeSuffix(arena, pwd);
+    const cache_dir_with_suffix = try std.fmt.allocPrint(arena, "{s}/{s}", .{ cache_dir, suffix });
+
     try env.put("ZIG_LIB_DIR", zig_lib_dir);
-    try env.put("ZIG_LOCAL_CACHE_DIR", cache_dir);
-    try env.put("ZIG_GLOBAL_CACHE_DIR", cache_dir);
+    try env.put("ZIG_LOCAL_CACHE_DIR", cache_dir_with_suffix);
+    try env.put("ZIG_GLOBAL_CACHE_DIR", cache_dir_with_suffix);
 
     // Zig 0.14.0 locates the macOS SDK by running `xcrun --show-sdk-path`.
     // Bazel clears PATH via `exec env -`, making xcrun unfindable. Restore
