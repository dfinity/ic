# fix for https://github.com/aws/aws-lc-rs/issues/1137
# can be removed when aws-lc-sys is updated
--- a/builder/cc_builder.rs
+++ b/builder/cc_builder.rs
@@ -474,6 +474,26 @@
                 .flag("-fwrapv")
                 .flag("-Wconversion");
         }
+
+        // The jitter-entropy builder does not inherit the flags set in
+        // collect_universal_build_options on the main cc_build. Without
+        // -ffile-prefix-map, jitterentropy objects bake the absolute manifest
+        // & break build reproducibility under Bazel (path includes the output base).
+        if !is_like_msvc {
+            let path = self.manifest_dir.display().to_string();
+            let file_flag = format!("-ffile-prefix-map={path}=");
+            if je_builder.is_flag_supported(&file_flag).unwrap_or(false) {
+                je_builder.flag(&file_flag);
+            } else {
+                je_builder.flag_if_supported(format!("-fdebug-prefix-map={path}="));
+            }
+            // -ffile-prefix-map covers __FILE__ and GCC's UBSan source locations
+            // but clang stores UBSan source locations in separate type-descriptor
+            // records that bypass file-prefix-map. At -O0 those records are not
+            // dead-code-eliminated and bake absolute paths into .rodata. Strip
+            // all but the basename. Silently ignored if UBSan is not enabled.
+            je_builder.flag_if_supported("-fsanitize-undefined-strip-path-components=-1");
+        }
         je_builder
     }

