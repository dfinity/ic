# Patch for determinism issues
# https://github.com/askama-rs/askama/issues/708
// When .file() returns a relative path (e.g. "src/lib.rs"), we need to
// resolve it to an absolute path so that diff_paths() can compute a correct
// relative path to the template files.
//
// We use CARGO_MANIFEST_DIR as the base because:
// 1. Template paths are resolved and canonicalized relative to CARGO_MANIFEST_DIR
//    (see Config::find_template and manifest_root in config.rs).
// 2. The .file() path from proc_macro is relative to the crate root, which is
//    what CARGO_MANIFEST_DIR points to.
// 3. CARGO_MANIFEST_DIR is a stable, deterministic value set by cargo — unlike
//    current_dir() which depends on where cargo was invoked from, or where a
//    build system chose to run rustc.
//
// This ensures include_bytes!() paths in generated code are relative (not
// absolute), making them identical across different checkouts and build
// directories.
diff --git a/askama_derive/src/generator.rs b/askama_derive/src/generator.rs
index 37c4fcb8..a71b44fa 100644
--- a/askama_derive/src/generator.rs
+++ b/askama_derive/src/generator.rs
@@ -136,18 +136,21 @@ impl<'a, 'h> Generator<'a, 'h> {
             CallerDir::Unresolved => {}
         }

-        if proc_macro::is_available()
-            && let Some(mut local_file) = proc_macro::Span::call_site().local_file()
-        {
-            local_file.pop();
-            if !local_file.is_absolute() {
-                local_file = current_dir()
-                    .as_deref()
-                    .unwrap_or(Path::new("."))
-                    .join(local_file);
+        if proc_macro::is_available() {
+            let file_str = proc_macro::Span::call_site().file();
+            let mut file = PathBuf::from(file_str);
+            file.pop();
+
+            if !file.is_absolute() {
+                if let Ok(manifest_dir) = std::env::var("CARGO_MANIFEST_DIR") {
+                    file = Path::new(&manifest_dir).join(file);
+                } else {
+                    self.caller_dir = CallerDir::Invalid;
+                    return None;
+                }
             }

-            self.caller_dir = CallerDir::Valid(clean_path(&local_file));
+            self.caller_dir = CallerDir::Valid(clean_path(&file));
             match &self.caller_dir {
                 CallerDir::Valid(caller_dir) => Some(caller_dir.as_path()),
                 _ => None, // unreachable
