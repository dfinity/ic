# Symlink the linker target's runfiles into the generated sysroot: https://github.com/bazelbuild/rules_rust/issues/3733
#
# `_symlink_sysroot_tree` takes a `target_files` argument (used by the linker to
# pass `rust-lld`'s runfiles, i.e. the bundled self-contained linker wrappers
# `lib/rustlib/<target>/bin/gcc-ld/*` such as `gcc-ld/ld.lld`), but the loop
# iterated `target.files` instead of `target_files`. As a result the `gcc-ld/*`
# files were never symlinked into the generated sysroot and thus never became
# declared inputs of the `Rustc` actions.
#
# Since rustc defaults to lld on x86_64-unknown-linux-gnu (it links via
# `-fuse-ld=lld -B<sysroot>/lib/rustlib/<target>/bin/gcc-ld`), local
# (non-sandboxed) builds still found `gcc-ld/ld.lld` on disk, but remote
# execution -- which ships only an action's declared inputs -- failed every
# Rustc link action (starting with the bootstrap `process_wrapper`) with:
#   error: the self-contained linker was requested, but it wasn't found in the
#   target's sysroot, or in rustc's sysroot
#
# `target_files` defaults to `target.files` when omitted, so the other callers
# (rustc_lib, llvm_tools, rust_std) are unaffected.
diff --git a/rust/toolchain.bzl b/rust/toolchain.bzl
--- a/rust/toolchain.bzl
+++ b/rust/toolchain.bzl
@@ -152,7 +152,7 @@ def _symlink_sysroot_tree(ctx, name, target, target_files = None):
     tree_files = []
     if target_files == None:
         target_files = target.files
-    for file in target.files.to_list():
+    for file in target_files.to_list():
         # Parse the path to the file relative to the workspace root so a
         # symlink matching this path can be created within the sysroot.
 
