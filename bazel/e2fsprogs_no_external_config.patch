# Make the compiled-in mke2fs.conf path build-location independent.
#
# mke2fs hardcodes `config_fn[] = { ROOT_SYSCONFDIR "/mke2fs.conf", 0 }`.
# Built via rules_foreign_cc, configure's --prefix is the absolute, per-build
# $BUILD_TMPDIR, so ROOT_SYSCONFDIR bakes that path into the binary's .rodata;
# two builds at different filesystem locations then differ, breaking
# reproducibility.
#
# That path never exists at runtime: build_ext4_image.py runs mke2fs with a
# scrubbed environment (no MKE2FS_CONFIG), so profile_init() returns ENOENT and
# mke2fs falls back to its compiled-in default profile. We make that explicit
# and build-independent with an empty config spec, keeping the build hermetic
# (no dependency on the container's /etc/mke2fs.conf) and reproducible.
diff --git a/misc/mke2fs.c b/misc/mke2fs.c
--- a/misc/mke2fs.c
+++ b/misc/mke2fs.c
@@ -1308,7 +1308,14 @@
 	exit(1);
 }

-static const char *config_fn[] = { ROOT_SYSCONFDIR "/mke2fs.conf", 0 };
+/*
+ * Empty by design: do not consult an external mke2fs.conf. The upstream
+ * default (ROOT_SYSCONFDIR "/mke2fs.conf") bakes the absolute build-time
+ * install prefix into the binary, which breaks reproducible builds. With an
+ * empty spec profile_init() returns ENOENT and mke2fs falls back to its
+ * compiled-in default profile -- identical to the file simply being absent.
+ */
+static const char *config_fn[] = { "", 0 };

 static void edit_feature(const char *str, __u32 *compat_array)
 {
