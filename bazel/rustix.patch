# Patch for determinism issues.
#
# rustix's build script probes the compiler with `can_compile()`, emitting the
# artifact `rustix_test_can_compile` into `OUT_DIR`. rules_rust captures the
# entire build-script `OUT_DIR` (`_bs.out_dir`) as a cacheable output, but this
# probe artifact is non-deterministic (it embeds compiler-internal metadata and
# the output path includes the strip-level `-ST-...` suffix), which breaks
# build determinism. We don't need the artifact, so remove it after probing.
diff --git a/build.rs b/build.rs
index 1677ece..d69d9f4 100644
--- a/build.rs
+++ b/build.rs
@@ -261,7 +261,7 @@ fn can_compile<T: AsRef<str>>(test: T) -> bool {
         .arg("--target")
         .arg(target)
         .arg("-o")
-        .arg(out_file)
+        .arg(&out_file)
         .stdout(Stdio::null()); // We don't care about the output (only whether it builds or not)
 
     // If Cargo wants to set RUSTFLAGS, use that.
@@ -282,5 +282,11 @@ fn can_compile<T: AsRef<str>>(test: T) -> bool {
 
     writeln!(child.stdin.take().unwrap(), "{}", test.as_ref()).unwrap();
 
-    child.wait().unwrap().success()
+    let success = child.wait().unwrap().success();
+
+    // Remove the non-deterministic probe artifact so it isn't captured as part
+    // of the build script's `OUT_DIR` output (breaks build determinism).
+    let _ = std::fs::remove_file(&out_file);
+
+    success
 }
