# Drop quinn-proto's wasm-target dependency block.
#
# Upstream quinn-proto declares four wasm-target deps to support its own
# browser-targeted builds:
#
#     [target.'cfg(all(target_family = "wasm", target_os = "unknown"))'.dependencies.getrandom]
#     features = ["wasm_js"]
#     [target.'cfg(...)'.dependencies.ring]
#     features = ["wasm32_unknown_unknown_js"]
#     [target.'cfg(...)'.dependencies.rustls-pki-types]
#     features = ["web"]
#     [target.'cfg(...)'.dependencies.web-time]
#
# The IC canister target is also `wasm32-unknown-unknown`. Cargo / cargo-bazel
# feature unification leaks these features into the workspace-wide feature set:
#
#   - ring's `wasm32_unknown_unknown_js` feature activates `getrandom/js` on
#     `getrandom 0.2.10`, which pulls `wasm-bindgen` + `js-sys` into the
#     `wasm32-unknown-unknown` deps of `getrandom 0.2.10`.
#   - getrandom 0.3's `wasm_js` feature does the same for that version.
#
# Either path causes `wasm-bindgen` to be linked into canister wasm,
# which the IC embedder rejects:
#
#     Module imports function '__wbindgen_describe' from
#     '__wbindgen_placeholder__' that is not exported by the runtime.
#
# IC never compiles quinn-proto for wasm — it is used only by the replica
# P2P stack (Linux) — so removing this entire block is a no-op for the
# actual build graph and clears the canister regression.
diff --git a/Cargo.toml b/Cargo.toml
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -171,17 +171,3 @@ default-features = false

 [dev-dependencies.wasm-bindgen-test]
 version = "0.3.45"
-
-[target.'cfg(all(target_family = "wasm", target_os = "unknown"))'.dependencies.getrandom]
-version = "0.3"
-features = ["wasm_js"]
-default-features = false
-
-[target.'cfg(all(target_family = "wasm", target_os = "unknown"))'.dependencies.ring]
-version = "0.17"
-features = ["wasm32_unknown_unknown_js"]
-
-[target.'cfg(all(target_family = "wasm", target_os = "unknown"))'.dependencies.rustls-pki-types]
-version = "1.7"
-features = ["web"]
-
-[target.'cfg(all(target_family = "wasm", target_os = "unknown"))'.dependencies.web-time]
-version = "1"
