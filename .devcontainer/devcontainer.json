{
  "image": "ghcr.io/dfinity/ic-dev@sha256:9dd85a1d598124c55012f93ae7a37e4f227de04a134c3a612b347d93f99cbcb6",
  "remoteUser": "ubuntu",
  "privileged": true,
  "runArgs": [
    "--hostname",
    "devenv-container",
    "--network",
    "host",
    "--cgroupns",
    "host",
    "--add-host",
    "devenv-container:127.0.0.1",
    // Grant the container's init process -- and therefore the VS Code server,
    // every integrated terminal, and the bazel server they spawn -- membership
    // in the group that owns the host's /dev/kvm, so the local system-test
    // backend's sandboxed QEMU can open /dev/kvm. Supplementary group membership
    // is fixed when a process is created, so it must be granted here (at
    // container creation); the postStartCommand runs too late to affect the
    // already-started server. This is purely a group membership on the container
    // side -- it modifies neither the host nor the /dev/kvm device node.
    //
    // It MUST be the numeric GID, not the name `kvm`: podman resolves a name
    // against the image's /etc/group, whose `kvm` group has an arbitrary
    // build-time GID unrelated to the host. On the dfinity devenv /dev/kvm is
    // owned by GID 993, which in this image is the `sgx` group -- the image's
    // `kvm` group has a different GID -- so `--group-add kvm` would add the
    // wrong group and QEMU still couldn't open /dev/kvm.
    // ci/container/container-run.sh applies the same membership but reads
    // the GID dynamically via `--group-add "$(stat -c %g /dev/kvm)"`; static
    // devcontainer.json can't run `stat`, so the devenv's known GID is pinned
    // here and must be updated if the host's /dev/kvm GID ever changes.
    "--group-add",
    "993"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/ic,type=bind",
  "workspaceFolder": "/ic",
  "initializeCommand": "mkdir -p ~/.aws ~/.ssh ~/.cache/cargo ~/.cache/zig-cache ~/.claude ~/.local/share/fish /tmp/ict_testnets && touch ~/.zsh_history ~/.bash_history",
  "containerEnv": {
    "CARGO_TARGET_DIR": "/home/ubuntu/.cache/cargo",
    "USER": "${localEnv:USER}"
  },
  "mounts": [
    {
      "source": "${localEnv:HOME}/.cache",
      "target": "/home/ubuntu/.cache",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.cache/zig-cache",
      "target": "/tmp/zig-cache",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.ssh",
      "target": "/home/ubuntu/.ssh",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.aws",
      "target": "/home/ubuntu/.aws",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.claude",
      "target": "/home/ubuntu/.claude",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.bash_history",
      "target": "/home/ubuntu/.bash_history",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.zsh_history",
      "target": "/home/ubuntu/.zsh_history",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.local/share/fish",
      "target": "/home/ubuntu/.local/share/fish",
      "type": "bind"
    },
    {
      "source": "/tmp/ict_testnets",
      "target": "/tmp/ict_testnets",
      "type": "bind"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "bazelbuild.vscode-bazel",
        "stackbuild.bazel-stack-vscode",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        // Exclude bazel output directories from search
        "search.exclude": {
          "bazel-bin/": true,
          "bazel-ic/": true,
          "bazel-out/": true,
          "targets/": true
        }
      }
    }
  }
}