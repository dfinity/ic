load("//bazel:defs.bzl", "file_size_check")
load("//ic-os:defs.bzl", "icos_build")
load("//ic-os/guestos:defs.bzl", "image_deps")
load("//publish:defs.bzl", "artifact_bundle")

package(default_visibility = ["//ic-os/guestos/envs/sev-recovery-dev:__pkg__"])

# The macro contains several targets.
# Check
#       //ic-os/guestos/BUILD.bazel for examples
#    or //ic-os/defs.bzl for the full list of targets.
icos_images = icos_build(
    name = "dev",
    image_deps_func = image_deps,
    visibility = [
        "//rs:ic-os-pkg",
        "//rs:system-tests-pkg",
    ],
)

file_size_check(
    name = "disk_img_size_check",
    file = icos_images.disk_image,
    # Raised from 600 MB to 650 MB to accommodate the AI extras bundled on this
    # branch (ollama binary, baked-in Gemma model under /opt/ollama-models, and
    # the AI agent). 580 MB on 2025-06-26; ~602 MB after AI extras.
    max_file_size = 650 * 1000 * 1000,
)

file_size_check(
    name = "update_img_size_check",
    file = icos_images.update_image,
    # See disk_img_size_check above for the rationale of the bump.
    # 578 MB on 2025-06-26; ~600 MB after AI extras.
    max_file_size = 650 * 1000 * 1000,
)

file_size_check(
    name = "update_img_test_size_check",
    file = icos_images.update_image_test,
    # See disk_img_size_check above for the rationale of the bump.
    # 578 MB on 2025-06-26; ~600 MB after AI extras.
    max_file_size = 650 * 1000 * 1000,
)

# Export checksums & build artifacts for update images
artifact_bundle(
    name = "bundle-update",
    inputs = [
        icos_images.update_image,
        icos_images.update_image_test,
        icos_images.launch_measurements,
    ],
    prefix = "guest-os/update-img-dev",
    visibility = ["//visibility:public"],
)
