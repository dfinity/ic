load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

package(default_visibility = ["//rs/nervous_system:default_visibility"])

LIB_SRCS = glob(
    ["src/**"],
    exclude = ["src/**/*tests.rs"],
)

rust_library(
    name = "lock",
    srcs = LIB_SRCS,
    crate_name = "ic_nervous_system_lock",
    version = "0.0.1",
)

rust_test(
    name = "lock_test",
    srcs = glob(["src/**/*.rs"]),
    deps = [
        "@crate_index//:futures",
        "@crate_index//:tokio",
    ],
)
