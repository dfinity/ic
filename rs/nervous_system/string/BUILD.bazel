load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

package(default_visibility = ["//visibility:public"])

LIB_SRCS = glob(
    ["src/**/*.rs"],
    # Ensures that we do not need to rebuild just because a _test.rs file
    # changed.
    exclude = ["**/*tests.rs"],
)

rust_library(
    name = "string",
    srcs = LIB_SRCS,
    crate_name = "ic_nervous_system_string",
    version = "0.0.1",
)

rust_test(
    name = "string_test",
    srcs = glob(["src/**/*.rs"]),
)
