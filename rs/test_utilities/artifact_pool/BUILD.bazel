load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

package(default_visibility = ["//visibility:public"])

rust_library(
    name = "artifact_pool",
    testonly = True,
    srcs = glob(["src/**"]),
    crate_name = "ic_test_artifact_pool",
    version = "0.9.0",
    deps = [
        # Keep sorted.
        "//rs/artifact_pool",
        "//rs/config",
        "//rs/consensus/dkg",
        "//rs/consensus/utils",
        "//rs/crypto/test_utils/crypto_returning_ok",
        "//rs/interfaces",
        "//rs/interfaces/registry",
        "//rs/interfaces/state_manager",
        "//rs/monitoring/logger",
        "//rs/monitoring/metrics",
        "//rs/registry/helpers",
        "//rs/replicated_state",
        "//rs/test_utilities/consensus",
        "//rs/test_utilities/types",
        "//rs/types/types",
    ],
)

rust_test(
    name = "artifact_pool_test",
    crate = ":artifact_pool",
    deps = [
        # Keep sorted.
        "//rs/artifact_pool",
        "//rs/config",
        "//rs/consensus/dkg",
        "//rs/consensus/utils",
        "//rs/crypto/test_utils/crypto_returning_ok",
        "//rs/interfaces",
        "//rs/interfaces/registry",
        "//rs/interfaces/state_manager",
        "//rs/monitoring/logger",
        "//rs/monitoring/metrics",
        "//rs/registry/helpers",
        "//rs/replicated_state",
        "//rs/test_utilities/consensus",
        "//rs/test_utilities/types",
        "//rs/types/types",
    ],
)
