load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

package(default_visibility = ["//visibility:public"])

rust_library(
    name = "metrics",
    srcs = glob(["src/**"]),
    crate_name = "ic_test_utilities_metrics",
    version = "0.9.0",
    deps = [
        # Keep sorted.
        "//rs/monitoring/metrics",
        "@crate_index//:prometheus",
    ],
)

rust_test(
    name = "metrics_test",
    crate = ":metrics",
)
