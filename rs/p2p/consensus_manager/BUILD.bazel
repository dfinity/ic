    name = "consensus_manager",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "ic_consensus_manager",
    version = "0.9.0",
    deps = [
        # Keep sorted.
        "//rs/interfaces",
        "//rs/limits",
