load("@rules_rust//rust:defs.bzl", "rust_library")
load("//bazel:canisters.bzl", "rust_canister")

package(default_visibility = [
    "//rs/nervous_system/agent:__pkg__",
    "//rs/nervous_system/canisters:__pkg__",
    "//rs/registry/admin:__pkg__",
])

rust_library(
    name = "fetch_large_record_test_canister",
    testonly = True,
    srcs = glob(
        ["src/**/*.rs"],
        exclude = [
            "src/main.rs",
            "src/**/*tests.rs",
        ],
    ),
    crate_name = "ic_registry_fetch_large_record_test_canister",
    version = "0.0.1",
    deps = [
        # Keep sorted.
        "//rs/crypto/sha2",
        "//rs/nervous_system/canisters",
        "//rs/registry/transport",
        "//rs/types/types",
        "@crate_index//:candid",
        "@crate_index//:ic-cdk",
        "@crate_index//:serde",
    ],
)

rust_canister(
    name = "canister",
    testonly = True,
    srcs = ["src/main.rs"],
    service_file = "interface.did",
    deps = [
        # Keep sorted.
        ":fetch_large_record_test_canister",
        "//rs/crypto/sha2",
        "//rs/nervous_system/canisters",
        "//rs/registry/transport",
        "//rs/types/types",
        "@crate_index//:candid",
        "@crate_index//:ic-cdk",
        "@crate_index//:serde",
    ],
)
