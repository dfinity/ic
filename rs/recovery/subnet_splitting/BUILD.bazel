        "//rs/state_manager",
        "//rs/state_tool:state_tool_lib",
        "//rs/types/base_types",
        "//rs/types/cycles",
        "//rs/types/types",
        "@crate_index//:anyhow",
        "@crate_index//:clap",
        "@crate_index//:csv",
        "@crate_index//:hex",
        "@crate_index//:ic-agent",
