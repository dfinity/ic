        "//rs/types/types",
        "//rs/universal_canister/lib",
        "@crate_index//:anyhow",
        "@crate_index//:candid",
        "@crate_index//:clap",
        "@crate_index//:csv",
        "@crate_index//:hex",
        "@crate_index//:ic-agent",
        "@crate_index//:serde",
        "@crate_index//:serde_cbor",
        "@crate_index//:slog",
        "@crate_index//:strum",
        "@crate_index//:url",
