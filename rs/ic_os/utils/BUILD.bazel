load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

package(default_visibility = ["//rs:ic-os-pkg"])

rust_library(
    name = "utils",
    srcs = glob(
        ["src/**/*.rs"],
    ),
    aliases = {},
    crate_name = "utils",
    proc_macro_deps = [],
    deps = [
        # Keep sorted.
        "@crate_index//:anyhow",
    ],
)

rust_test(
    name = "test",
    size = "small",
    crate = ":utils",
    deps = [
        # Keep sorted.
        "@crate_index//:anyhow",
    ],
)
