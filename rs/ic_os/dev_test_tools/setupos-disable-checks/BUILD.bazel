load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_test")

package(default_visibility = ["//rs:ic-os-pkg"])

rust_binary(
    name = "setupos-disable-checks",
    srcs = glob(["src/**/*.rs"]),
    proc_macro_deps = [
        # Keep sorted.
        "@crate_index//:indoc",
    ],
    version = "0.1.0",
    visibility = [
        "//rs:ic-os-pkg",
        "//rs:system-tests-pkg",
    ],
    deps = [
        # Keep sorted.
        "//rs/ic_os/build_tools/partition_tools",
        "//rs/ic_os/linux_kernel_command_line",
        "@crate_index//:anyhow",
        "@crate_index//:clap",
        "@crate_index//:regex",
        "@crate_index//:tempfile",
    ],
)

rust_test(
    name = "unit_tests",
    crate = ":setupos-disable-checks",
    proc_macro_deps = [
        # Keep sorted.
        "@crate_index//:indoc",
    ],
    deps = [
        # Keep sorted.
        "//rs/ic_os/build_tools/partition_tools",
        "//rs/ic_os/linux_kernel_command_line",
        "@crate_index//:anyhow",
        "@crate_index//:clap",
        "@crate_index//:regex",
        "@crate_index//:tempfile",
    ],
)
