<domain type='kvm'>
  <name>{{ domain_name }}</name>
  <uuid>{{ domain_uuid }}</uuid>
  <memory unit='KiB'>{{ vm_memory_kib }}</memory>
  <currentMemory unit='KiB'>{{ vm_memory_kib }}</currentMemory>
  <vcpu placement='static'>{{ nr_of_vcpus }}</vcpu>
  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <loader readonly='yes' type='pflash'>/usr/share/OVMF/OVMF_CODE_4M.fd</loader>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
    <apic/>
  </features>
  <cpu mode='host-model'/>
  <clock offset='utc'/>
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>
  <devices>
    <emulator>/usr/bin/qemu-system-x86_64</emulator>
    {% for d in disks %}
    <disk type='file' device='disk'>
      <driver name='qemu' type='raw' cache='none' discard='unmap'/>
      <source file='{{ d.file }}'/>
      <target dev='{{ d.target }}' bus='{{ d.bus }}'/>
    </disk>
    {% endfor %}
    <!--
      Pin the NIC(s) to dedicated PCIe root ports with explicit bus numbers so
      the guest's predictable interface names are deterministic regardless of
      how many disks are attached: bus 1 -> enp1s0 (primary), bus 2 -> enp2s0
      (IPv4). Disks auto-assign to other root ports.
    -->
    <controller type='pci' index='1' model='pcie-root-port'/>
    <interface type='ethernet'>
      <mac address='{{ mac_address }}'/>
      <target dev='{{ tap_name }}' managed='no'/>
      <model type='virtio'/>
      <address type='pci' domain='0x0000' bus='0x01' slot='0x00' function='0x0'/>
    </interface>
    {% if has_ipv4 %}
    <controller type='pci' index='2' model='pcie-root-port'/>
    <interface type='ethernet'>
      <mac address='{{ mac_address_ipv4 }}'/>
      <target dev='{{ tap_name_ipv4 }}' managed='no'/>
      <model type='virtio'/>
      <address type='pci' domain='0x0000' bus='0x02' slot='0x00' function='0x0'/>
    </interface>
    {% endif %}
    <!--
      `append='on'` keeps the console log across domain (re)starts. The Local
      backend restarts the same transient domain on guest-initiated reboots
      (`<on_reboot>restart</on_reboot>`) and on `vm().kill()` + `vm().start()`;
      with the default `append='off'` QEMU would truncate the file on every such
      restart, discarding the pre-reboot console output that `log_consoles_task`
      streams to the test log. The `<console>` with `target type='serial'` is the
      same device as serial port 0 (it does not add a second writer), so the file
      grows monotonically and the streamer can simply tail it.
    -->
    <serial type='file'>
      <source path='{{ console_log_path }}' append='on'/>
      <target type='isa-serial' port='0'>
        <model name='isa-serial'/>
      </target>
    </serial>
    <console type='file'>
      <source path='{{ console_log_path }}' append='on'/>
      <target type='serial' port='0'/>
    </console>
    <memballoon model='virtio'/>
    <rng model='virtio'>
      <backend model='random'>/dev/urandom</backend>
    </rng>
  </devices>
</domain>
