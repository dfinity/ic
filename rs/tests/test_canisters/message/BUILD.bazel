load("@rules_rust//rust:defs.bzl", "rust_library")
load("//bazel:canisters.bzl", "rust_canister")

package(default_visibility = ["//rs:system-tests-pkg"])

rust_library(
    name = "lib",
    srcs = [
        "src/lib.rs",
    ],
    crate_name = "ic_message",
    deps = [
        # Keep sorted.
        "@crate_index//:candid",
        "@crate_index//:serde",
    ],
)

rust_canister(
    name = "message",
    srcs = [
        "src/main.rs",
    ],
    crate_name = "message",
    service_file = ":src/message.did",
    version = "0.1.0",
    deps = [
        # Keep sorted.
        "//rs/tests/test_canisters/message:lib",
        "@crate_index//:candid",
        "@crate_index//:ic-cdk",
        "@crate_index//:serde",
    ],
)
