load("//bazel:canisters.bzl", "rust_canister")

package(default_visibility = ["//rs:system-tests-pkg"])

rust_canister(
    name = "http_counter",
    srcs = [
        "src/canister.rs",
    ],
    crate_name = "http_counter",
    service_file = ":src/http_counter.did",
    version = "0.1.0",
    deps = [
        # Keep sorted.
        "@crate_index//:candid",
        "@crate_index//:ic-cdk",
        "@crate_index//:ic-certified-map",
        "@crate_index//:serde",
    ],
)
