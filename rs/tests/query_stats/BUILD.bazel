load("//rs/tests:common.bzl", "DEFAULT_VCPUS_PER_VM", "MIN_LOCAL_CPUS", "UNIVERSAL_CANISTER_RUNTIME_DEPS")
load("//rs/tests:system_tests.bzl", "system_test")

package(default_visibility = ["//rs:system-tests-pkg"])

system_test(
    name = "query_stats_basic",
    cpus = MIN_LOCAL_CPUS + 5 * DEFAULT_VCPUS_PER_VM,  # 5 IC Node VMs * 6 vCPUs.
    tags = [
        "long_test",  # since it takes longer than 5 minutes.
    ],
    runtime_deps = UNIVERSAL_CANISTER_RUNTIME_DEPS,
    deps = [
        "//rs/tests/driver:ic-system-test-driver",
        "//rs/tests/query_stats/lib",
        "@crate_index//:anyhow",
    ],
)

