load("//rs/tests:system_tests.bzl", "system_test")

package(default_visibility = ["//rs:system-tests-pkg"])

system_test(
    name = "sns_sale_load_test_1",
    cpus = MIN_LOCAL_CPUS + 3 * 4 * 2,  # setup (sns_setup_fast): 3 IC subnets * 4 nodes (SUBNET_SIZE) * 2 vCPUs (IC-level resource override).
    tags = [
        "manual",
    ],
    test_timeout = "eternal",
    runtime_deps = NNS_CANISTER_RUNTIME_DEPS | SNS_CANISTER_RUNTIME_DEPS,
    deps = [
        "//rs/tests/driver:ic-system-test-driver",
        "//rs/tests/nns/sns/lib:sns_system_test_lib",
        "@crate_index//:anyhow",
    ],
)

