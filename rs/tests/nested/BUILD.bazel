load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library")
load("//rs/tests:common.bzl", "DEFAULT_VCPUS_PER_VM", "IC_GATEWAY_RUNTIME_DEPS", "MAINNET_ENV", "MIN_LOCAL_CPUS")
load("//rs/tests:system_tests.bzl", "system_test_nns")

package(default_visibility = ["//rs:system-tests-pkg"])

rust_library(
    name = "nested",
    testonly = True,
    srcs = glob(["src/**/*.rs"]),
    crate_name = "nested",
    target_compatible_with = ["@platforms//os:linux"],  # requires libssh that does not build on Mac OS
    deps = [
        # Keep sorted.
        "//rs/canister_client",
        "//rs/ic_os/dev_test_tools/bare_metal_deployment",
        "//rs/nervous_system/common/test_keys",
        "//rs/nns/common",
        "//rs/protobuf",
        "//rs/registry/subnet_type",
        "//rs/rust_canisters/canister_test",
        "//rs/tests/consensus/utils",
        "//rs/tests/driver:ic-system-test-driver",
        "//rs/types/types",
        "@crate_index//:anyhow",
        "@crate_index//:regex",
        "@crate_index//:reqwest",
        "@crate_index//:slog",
    ],
)

genrule(
    name = "empty-disk-img-tar-zst",
    outs = ["empty-disk-img.tar.zst"],
    cmd = """
        truncate -s 101G disk.img
        tar --zstd -Scf $@ disk.img
    """,
    tags = ["manual"],
    target_compatible_with = ["@platforms//os:linux"],
    visibility = ["//visibility:public"],
)

system_test_nns(
    name = "registration",
    # TODO: support this test on the local backend (drop `backend = "farm"`).
    # This is a nested test (SetupOS -> HostOS -> GuestOS). The local backend does
    # not yet implement nested VMs: `setup_and_start_nested_vms`
    # (rs/tests/driver/src/driver/bootstrap.rs) only has a Farm code path and calls
    # into Farm directly to upload the config image, attach the SetupOS disk image
    # and start the nested VM. Supporting this requires adding a
    # `SystemTestBackend::Local` branch that boots the nested VM via the local
    # QEMU-based backend.
    backend = "farm",
    cpus = MIN_LOCAL_CPUS + 3 * DEFAULT_VCPUS_PER_VM + 1 * 8,  # 1 System node + 1 API boundary node + 1 ic-gateway VM (6 vCPUs each) + 1 nested HostOS node (8 vCPUs).
    env = MAINNET_ENV,
    setupos = True,
    tags = ["long_test"],  # since it takes longer than 5 minutes.
    test_timeout = "eternal",
    runtime_deps = IC_GATEWAY_RUNTIME_DEPS,
    deps = [
        # Keep sorted.
        ":nested",
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:anyhow",
    ],
)

rust_binary(
    name = "guestos_upgrade_test_bin",
    testonly = True,
    srcs = ["guestos_upgrade.rs"],
    deps = [
        # Keep sorted.
        ":nested",
        "//rs/registry/nns_data_provider",
        "//rs/tests/driver:ic-system-test-driver",
        "//rs/types/types",
        "@crate_index//:anyhow",
        "@crate_index//:reqwest",
        "@crate_index//:slog",
    ],
)

# Tests if current commit is "upgradeable" and can be used as an upgrade image
system_test_nns(
    name = "guestos_upgrade_smoke_test",
    # TODO: support this test on the local backend (drop `backend = "farm"`).
    # This is a nested test (SetupOS -> HostOS -> GuestOS). The local backend
    # does not yet implement nested VMs: `setup_and_start_nested_vms`
    # (rs/tests/driver/src/driver/bootstrap.rs) only has a Farm code path and
    # calls into Farm directly to upload the config image, attach the SetupOS
    # disk image and start the nested VM. Supporting this requires adding a
    # `SystemTestBackend::Local` branch that boots the nested VM via the local
    # QEMU-based backend.
    backend = "farm",
    cpus = MIN_LOCAL_CPUS + 3 * DEFAULT_VCPUS_PER_VM + 1 * 8,  # 1 System node + 1 API boundary node + 1 ic-gateway VM (6 vCPUs each) + 1 nested HostOS node (8 vCPUs).
    env = MAINNET_ENV,
    guestos_update = "test",
    setupos = True,
    tags = ["long_test"],
    test_driver_target = ":guestos_upgrade_test_bin",
    test_timeout = "eternal",
    runtime_deps = IC_GATEWAY_RUNTIME_DEPS,
)

# Tests if the current GuestOS version on a bare-metal SEV-enabled node can successfully
# upgrade to the current test image.
# This test requires manually injecting the baremetal configuration.
# bazel test //rs/tests/nested:guestos_upgrade_from_current_to_current_test_sev --test_env=BARE_METAL_HOST_SECRETS="$(realpath zh2-dll01.ini)"
# zh2-dll01.ini can be retrieved from our 1password
system_test_nns(
    name = "guestos_upgrade_from_current_to_current_test_sev",
    cpus = MIN_LOCAL_CPUS + 3 * DEFAULT_VCPUS_PER_VM,  # 1 System node + 1 API boundary node + 1 ic-gateway VM (6 vCPUs each); the bare-metal SEV HostOS node is external hardware, not a Farm VM.
    env = MAINNET_ENV | {"TRUSTED_EXECUTION_ENVIRONMENT": "true"},
    guestos = True,
    guestos_update = "test",
    hostos = True,
    tags = [
        "manual",
    ],
    test_driver_target = ":guestos_upgrade_test_bin",
    test_timeout = "eternal",
    runtime_deps = IC_GATEWAY_RUNTIME_DEPS | {
        "NODE_OPERATOR_PRIV_KEY_PATH": "//ic-os/setupos:config/node_operator_private_key.pem",
    },
)

