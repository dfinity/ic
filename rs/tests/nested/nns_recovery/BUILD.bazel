package(default_visibility = ["//rs:system-tests-pkg"])

ENV = MAINNET_ENV

RUNTIME_DEPS = CANISTER_SANDBOX_RUNTIME_DEPS | IC_GATEWAY_RUNTIME_DEPS | MESSAGE_CANISTER_RUNTIME_DEPS | IMPERSONATE_UPSTREAMS_RUNTIME_DEPS | {
    "RECOVERY_GUESTOS_IMG_PATH": "//ic-os/guestos/envs/recovery-dev:update-img.tar.zst",
}

rust_library(
    name = "common",
    testonly = True,
    srcs = ["common.rs"],
    crate_name = "ic_nested_nns_recovery_common",
    deps = [
        # Keep sorted.
        "//rs/ic_os/os_tools/manual_guestos_recovery",
        "//rs/nervous_system/root",
        "//rs/recovery",
        "//rs/tests/consensus/subnet_recovery:lib",
