system_test_nns(
    name = "upgrade_downgrade_app_subnet_test",
    # TODO: support this test on the local backend (drop `backend = "farm"`).
    # The mainnet GuestOS images are served correctly by the local backend's file
    # server, but the subnet upgrade does not complete within the test's deadline:
    # after a node is stopped and the upgrade is proposed, the (small) subnet does
    # not make enough consensus progress under the chain-key workload to finalize
    # the upgrade CUP, so the faulty node never picks up the new version and the
    # test fails with `Replica was running the old version only!`
    # (rs/tests/consensus/utils/src/upgrade.rs). Making this pass on the local
    # backend needs the upgrade to reliably complete there first.
    backend = "farm",
    colocated_test_driver_vm_resources = {
        "vcpus": 24,
    },
    cpus = MIN_LOCAL_CPUS + 5 * DEFAULT_VCPUS_PER_VM,  # 5 IC Node VMs * 6 vCPUs (1 System + 4 Application).
    env = MAINNET_ENV,
    guestos = "mainnet_app",
    guestos_update = True,
    tags = [
        "colocate",
        "long_test",
    ],
    test_driver_target = ":upgrade_downgrade_app_test_bin",
    test_timeout = "eternal",
    runtime_deps = MESSAGE_CANISTER_RUNTIME_DEPS,
)

