# ict testnet create launch_single_host
# Or, to measure startup time:
# bazel run //rs/tests/node:launch_single_host -- --quiet
system_test(
    name = "launch_single_host",
    cpus = MIN_LOCAL_CPUS + 1 * 8,  # 1 Nested/HostOS Node VM * 8 vCPUs.
    guestos = False,
    setupos = True,
    tags = [
        "dynamic_testnet",
        "manual",
    ],
    deps = [
        # Keep sorted.
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:anyhow",
        "@crate_index//:slog",
    ],
)

rust_binary(
    name = "kill_start_test_bin",
    testonly = True,
    srcs = ["kill_start_test.rs"],
    deps = [
        # Keep sorted.
        "//rs/registry/subnet_type",
        "//rs/tests/driver:ic-system-test-driver",
        "//rs/tests/nested",
        "@crate_index//:anyhow",
        "@crate_index//:slog",
    ],
)

# Tests if killing and starting a node does not corrupt its filesystem.
# Doesn't run on PRs by default since we do multiple kill-start iterations which takes around 7 minutes.
system_test(
    name = "kill_start_long_test",
    cpus = MIN_LOCAL_CPUS + 1 * DEFAULT_VCPUS_PER_VM,  # 1 IC Node VM * 6 vCPUs.
    env = {
        "NUM_KILL_START_ITERATIONS": "5",
    },
    tags = ["long_test"],
    test_driver_target = ":kill_start_test_bin",
)

# Tests if killing and starting a node still allows the node to boot normally.
system_test(
    name = "kill_start_short_test",
    cpus = MIN_LOCAL_CPUS + 1 * DEFAULT_VCPUS_PER_VM,  # 1 IC Node VM * 6 vCPUs.
    env = {
        "NUM_KILL_START_ITERATIONS": "1",
    },
    test_driver_target = ":kill_start_test_bin",
)

# Tests that no systemd units have failed on GuestOS nodes after they boot.
system_test(
    name = "guestos_no_failed_systemd_units",
    cpus = MIN_LOCAL_CPUS + 1 * DEFAULT_VCPUS_PER_VM,  # 1 IC Node VM * 6 vCPUs.
    deps = [
        # Keep sorted.
        "//rs/registry/subnet_type",
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:anyhow",
        "@crate_index//:slog",
    ],
)
