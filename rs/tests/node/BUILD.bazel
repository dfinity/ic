load("@rules_rust//rust:defs.bzl", "rust_binary")
load("//rs/tests:common.bzl", "DEFAULT_VCPUS_PER_VM", "MIN_LOCAL_CPUS")
load("//rs/tests:system_tests.bzl", "system_test", "system_test_nns", "uvm_config_image")

package(default_visibility = ["//rs:system-tests-pkg"])

system_test_nns(
    name = "ipv4_integration_test",
    cpus = MIN_LOCAL_CPUS + 3 * DEFAULT_VCPUS_PER_VM,  # 3 IC Node VMs (1 System + 1 Application + 1 unassigned) * 6 vCPUs.
    proc_macro_deps = [
        "@crate_index//:indoc",
    ],
    tags = [
        "long_test",  # The P90 duration of this test was over 5 minutes for the week starting on 2025-08-21.
    ],
    deps = [
        "//rs/nns/constants",
        "//rs/registry/canister",
        "//rs/registry/canister/api",
        "//rs/registry/subnet_type",
        "//rs/tests/driver:ic-system-test-driver",
        "//rs/types/base_types",
        "@crate_index//:anyhow",
        "@crate_index//:candid",
        "@crate_index//:ic-agent",
        "@crate_index//:k256",
        "@crate_index//:slog",
        "@crate_index//:tokio",
    ],
)

# Unit tests that require root privileges to run.
system_test(
    name = "root_tests",
    cpus = MIN_LOCAL_CPUS + 1 * DEFAULT_VCPUS_PER_VM,  # 1 UniversalVm * 6 vCPUs.
    guestos = False,
    proc_macro_deps = [
        "@crate_index//:indoc",
    ],
    runtime_deps = {
        "NODE_ROOT_TESTS_UVM_CONFIG_PATH": ":root_tests_config_image",
    },
    deps = [
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:anyhow",
        "@crate_index//:slog",
    ],
)

uvm_config_image(
    name = "root_tests_config_image",
    testonly = True,
    srcmap = {
        "//rs/ic_os/device:device_test": "device_test",
        "//rs/ic_os/os_tools/guest_disk:guest_disk_test": "guest_disk_test",
        "//rs/ic_os/os_tools/guest_vm_runner:upgrade_device_mapper_test": "upgrade_device_mapper_test",
        "//rs/tests:ubuntu_test_runtime.tar": "ubuntu_test_runtime.tar",
    },
    tags = ["manual"],
)

system_test(
    name = "reboot_toy",
    cpus = MIN_LOCAL_CPUS + 1 * DEFAULT_VCPUS_PER_VM,  # 1 IC Node VM * 6 vCPUs.
    tags = [
        "manual",
    ],
    deps = [
        # Keep sorted.
        "//rs/registry/subnet_type",
        "//rs/tests/consensus/utils",
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:anyhow",
        "@crate_index//:slog",
    ],
)

