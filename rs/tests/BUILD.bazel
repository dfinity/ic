load("@aspect_bazel_lib//lib:tar.bzl", "tar")
load("@rules_distroless//apt:defs.bzl", "dpkg_status")
load("@rules_distroless//distroless:defs.bzl", "cacerts", "flatten", "passwd")
load("@rules_oci//oci:defs.bzl", "oci_image")
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load(":system_tests.bzl", "oci_tar", "uvm_config_image")

package(default_visibility = ["//rs:system-tests-pkg"])

exports_files([
    "counter.wat",
])

# Packages we install into the image; see base image definition and its
# 'manifest = ...' field for more information
PACKAGES = [
    "@resolute//bash/amd64",
    "@resolute//ca-certificates/amd64",
    "@resolute//coreutils-from-uutils/amd64",
    "@resolute//libcryptsetup-dev/amd64",
    "@resolute//dmsetup/amd64",
    "@resolute//dosfstools/amd64",
    "@resolute//e2fsprogs/amd64",
    "@resolute//gawk/amd64",
    "@resolute//gzip/amd64",
    "@resolute//libssl3t64/amd64",
    "@resolute//libunwind8/amd64",
    "@resolute//mtools/amd64",
    "@resolute//openssh-client/amd64",
    "@resolute//rsync/amd64",
    "@resolute//tar/amd64",
    "@resolute//udev/amd64",
    "@resolute//xz-utils/amd64",
    "@resolute//zstd/amd64",
]

tar(
    name = "sh",
    mtree = [
        # needed as dpkg assumes sh is installed in a typical debian installation.
        "./usr/bin/sh type=link link=/bin/bash",
    ],
)

tar(
    name = "awk",
    mtree = [
        # we install the GNU variant but call 'awk' so we symlink
        "./usr/bin/awk type=link link=/usr/bin/gawk",
    ],
)

# Needed because reqwest 0.13 switched to `rustls-platform-verifier`, which on Linux reads
# from `/etc/ssl/certs/ca-certificates.crt`. This rule creates that bundle from the cert package;
# the old `rustls-native-certs` (reqwest 0.12) could find individual cert files without it.
cacerts(
    name = "ca_certificates",
    package = "@resolute//ca-certificates/amd64:data",
)

# Creates /var/lib/dpkg/status with installed package information.
dpkg_status(
    name = "dpkg_status",
    controls = [
        "%s:control" % package
        for package in PACKAGES
    ],
    target_compatible_with = [
        "@platforms//os:linux",
    ],
)

passwd(
    name = "passwd",
    entries = [
        dict(
            gecos = ["root"],
            gid = 0,
            home = "/root",
            shell = "/usr/bin/bash",
            uid = 0,
            username = "root",
        ),
    ],
)

UBUNTU_PACKAGES = [
    ":dpkg_status",
    ":passwd",  # needed because we ssh in

    # symlinks
    ":awk",
    ":sh",
] + PACKAGES

flatten(
    name = "ubuntu_packages_tar",
    deduplicate = True,
    target_compatible_with = ["@platforms//os:linux"],
    tars = UBUNTU_PACKAGES,
)

oci_image(
    name = "ubuntu_test_runtime_image_src",
    architecture = "amd64",
    os = "linux",
    target_compatible_with = ["@platforms//os:linux"],
    tars = [
        ":ubuntu_packages_tar",
        ":ca_certificates",
    ],
)

oci_tar(
    name = "ubuntu_test_runtime.tar",
    image = ":ubuntu_test_runtime_image_src",
    repo_tags = ["ubuntu_test_runtime:image"],
)

uvm_config_image(
    name = "colocate_uvm_config_image",
    srcmap = {
        ":ubuntu_test_runtime.tar": "ubuntu_test_runtime.tar",
        "//rs/tests:activate-systest-uvm-config": "activate",
    },
    tags = ["manual"],  # this target will be built if required as a dependency of another target
)

exports_files([
    "create-universal-vm-config-image.sh",
])

oci_tar(
    name = "static-file-server.tar",
    image = "@static-file-server",
    repo_tags = ["static-file-server:image"],
)

exports_files([
    "jaeger_activate.sh",
])

uvm_config_image(
    name = "jaeger_uvm_config_image",
    srcmap = {
        ":jaeger.tar": "jaeger.tar",
        ":jaeger_activate.sh": "activate",
    },
    tags = ["manual"],  # this target will be built if required as a dependency of another target
)

exports_files([
    "src/canister_http/universal_vm_activation.sh",
])

oci_tar(
    name = "jaeger.tar",
    image = "@jaeger",
    repo_tags = ["jaegertracing/all-in-one:1.58"],
)

oci_tar(
    name = "minica.tar",
    image = "@minica",
    repo_tags = ["minica:image"],
)

oci_tar(
    name = "bitcoind.tar",
    image = "@bitcoind",
    repo_tags = ["bitcoind:image"],
)

oci_tar(
    name = "dogecoind.tar",
    image = "@dogecoind",
    repo_tags = ["dogecoind:image"],
)

oci_tar(
    name = "ic_gatewayd.tar",
    image = "@ic_gatewayd",
    repo_tags = ["ic_gatewayd:image"],
)

oci_tar(
    name = "nginx-proxy.tar",
    image = "@nginx-proxy",
    repo_tags = ["nginx-proxy:image"],
)

uvm_config_image(
    name = "ckbtc_uvm_config_image",
    srcmap = {
        ":bitcoind.tar": "bitcoind.tar",
        ":dogecoind.tar": "dogecoind.tar",
        ":minica.tar": "minica.tar",
        ":nginx-proxy.tar": "nginx-proxy.tar",
        "//ic-os/components:networking/dev-certs/canister_http_test_ca.cert": "cert.pem",
        "//ic-os/components:networking/dev-certs/canister_http_test_ca.key": "key.pem",
        "//rs/tests/httpbin-rs:httpbin.tar": "httpbin.tar",
    },
    tags = ["manual"],  # this target will be built if required as a dependency of another target
)

uvm_config_image(
    name = "impersonate_upstreams_uvm_config_image",
    srcmap = {
        ":minica.tar": "minica.tar",
        ":static-file-server.tar": "static-file-server.tar",
        "//ic-os/components:networking/dev-certs/canister_http_test_ca.cert": "minica.pem",
        "//ic-os/components:networking/dev-certs/canister_http_test_ca.key": "minica-key.pem",
    },
    tags = ["manual"],  # this target will be built if required as a dependency of another target
)

uvm_config_image(
    name = "ic_gateway_uvm_config_image",
    srcmap = {
        ":ic_gatewayd.tar": "ic_gatewayd.tar",
    },
    tags = ["manual"],  # this target will be built if required as a dependency of another target
)

oci_tar(
    name = "vector-with-log-fetcher.tar",
    image = "@vector-with-log-fetcher",
    repo_tags = [
        "vector-with-log-fetcher:image",
    ],
)

exports_files([
    "vector_activate.sh",
])

uvm_config_image(
    name = "vector_with_log_fetcher_image",
    srcmap = {
        ":vector-with-log-fetcher.tar": "vector-with-log-fetcher.tar",
        ":vector_activate.sh": "activate",
    },
    tags = ["manual"],
)

sh_binary(
    name = "upload_systest_dep",
    srcs = ["upload_systest_dep.sh"],
    visibility = ["//visibility:public"],
)

sh_binary(
    name = "run_systest",
    srcs = ["run_systest.sh"],
    visibility = ["//visibility:public"],
)

# the STABLE_VERSION, suffixed with `-test`. Used in testing.
genrule(
    name = "version-test",
    srcs = ["//bazel:version.txt"],
    outs = ["version-test.txt"],
    cmd = "sed < $< 's/$$/-test/' > $@",
)
