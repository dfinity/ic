load("@rules_rust//rust:defs.bzl", "rust_library")
load("//rs/tests:common.bzl", "DEFAULT_VCPUS_PER_VM", "MIN_LOCAL_CPUS")
load("//rs/tests:system_tests.bzl", "system_test_nns")

package(default_visibility = ["//rs:system-tests-pkg"])

rust_library(
    name = "ic_firewall_system_test_utils",
    testonly = True,
    srcs = ["utils.rs"],
    crate_name = "ic_firewall_system_test_utils",
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        # Keep sorted.
        "//rs/nns/governance/api",
        "//rs/protobuf",
        "//rs/registry/canister",
        "//rs/registry/keys",
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:candid",
        "@crate_index//:slog",
    ],
)

system_test_nns(
    name = "firewall_max_connections_test",
    cpus = MIN_LOCAL_CPUS + DEFAULT_VCPUS_PER_VM + 2 * DEFAULT_VCPUS_PER_VM,  # 1 Universal VM (6 vCPUs) + 2 IC Node VMs * 6 vCPUs.
    tags = [
        "colocate",
    ],
    deps = [
        "//rs/registry/subnet_type",
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:anyhow",
        "@crate_index//:slog",
        "@crate_index//:tokio",
    ],
)

system_test_nns(
    name = "firewall_correctness_test",
    cpus = MIN_LOCAL_CPUS + 6 * DEFAULT_VCPUS_PER_VM,  # 5 IC Node VMs (System 1 + Application 2 + CloudEngine 2) + 1 API boundary node VM, all 6 vCPUs.
    deps = [
        ":ic_firewall_system_test_utils",
        "//rs/protobuf",
        "//rs/registry/keys",
        "//rs/registry/subnet_type",
        "//rs/tests/consensus/utils",
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:anyhow",
        "@crate_index//:slog",
        "@crate_index//:tokio",
    ],
)

system_test_nns(
    name = "firewall_priority_test",
    cpus = MIN_LOCAL_CPUS + 3 * DEFAULT_VCPUS_PER_VM,  # 3 IC Node VMs (System 1 + Application 2) * 6 vCPUs.
    deps = [
        ":ic_firewall_system_test_utils",
        "//rs/protobuf",
        "//rs/registry/keys",
        "//rs/registry/subnet_type",
        "//rs/tests/driver:ic-system-test-driver",
        "@crate_index//:anyhow",
        "@crate_index//:reqwest",
        "@crate_index//:slog",
        "@crate_index//:url",
    ],
)
