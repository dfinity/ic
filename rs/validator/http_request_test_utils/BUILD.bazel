load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

package(default_visibility = ["//visibility:public"])

rust_library(
    name = "http_request_test_utils",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "ic_validator_http_request_test_utils",
    proc_macro_deps = [
        # Keep sorted.
        "@crate_index//:strum_macros",
    ],
    deps = [
        # Keep sorted.
        "//rs/canister_client/sender",
        "//rs/certification/test-utils",
        "//rs/crypto/iccsa",
        "//rs/crypto/iccsa/test_utils",
        "//rs/crypto/internal/crypto_lib/basic_sig/der_utils",
        "//rs/crypto/internal/crypto_lib/threshold_sig/bls12_381",
        "//rs/crypto/internal/crypto_lib/types",
        "//rs/crypto/secrets_containers",
        "//rs/crypto/test_utils",
        "//rs/crypto/tree_hash",
        "//rs/types/types",
        "@crate_index//:rand",
        "@crate_index//:simple_asn1",
        "@crate_index//:strum",
    ],
)

rust_test(
    name = "http_request_test_utils_test",
    crate = ":http_request_test_utils",
    deps = [
        # Keep sorted.
        "//packages/ic-ed25519",
        "//rs/crypto/test_utils/reproducible_rng",
        "@crate_index//:assert_matches",
    ],
)
